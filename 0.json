        "vodName": "vod_name",
        "vodId": "vod_id",
        "typeId": "type_id",
        "typeName": "type_name",
        "vodPic": "vod_pic",
        "vodRemarks": "vod_remarks",
        "vodActor": "vod_actor",
        "vodDirector": "vod_director",
        "vodContent": "vod_content",
        "vodYear": "vod_year",
        "playFrom": "vod_play_from",
        "playNote": "vod_play_note"
